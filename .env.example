BOT_TOKEN=your_telegram_bot_token_here

# Google Sheets
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
SPREADSHEET_ID=your_google_spreadsheet_id_here

# Sheet names (можно не менять — используются имена по умолчанию)
# SHEET_USERS=users
# SHEET_TEACHERS=teachers
# SHEET_STUDENTS=students
# SHEET_LESSONS=lessons
# SHEET_BILLING=billing
# SHEET_PAYMENTS=student_period_payments

# ── Продакшен (Railway) ──────────────────────────────────────────────────────

# Webhook: задайте публичный URL сервиса (Railway → Settings → Domains)
# Если не задан — бот запускается в режиме polling (удобно для локальной разработки)
# WEBHOOK_URL=https://fokus-bot.railway.app

# PORT задаётся Railway автоматически. Менять только для локального тестирования вебхука.
# PORT=8080

# Redis: подключите Redis-плагин в Railway и вставьте REDIS_URL из его настроек.
# Если не задан — используется MemoryStorage (FSM-состояния сбрасываются при рестарте).
# REDIS_URL=redis://default:password@redis.railway.internal:6379
